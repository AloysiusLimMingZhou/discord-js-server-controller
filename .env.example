# Discord Bot
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-client-id
DISCORD_GUILD_ID=your-guild-id
DISCORD_CHANNEL_ID=channel-id-for-notifications

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCP_ZONE=us-central1-a
GCP_INSTANCE_NAME=your-vm-instance-name

# GCP Service Account Key path
SA_KEY=/path/to/gcp-sa-key.json

# Express
EXPRESS_PORT=3000

# Monitoring (pushed from G2 server)
MONITOR_CPU_THRESHOLD=80          # CPU % to trigger alert (default: 80)
MONITOR_GPU_THRESHOLD=80          # GPU % to trigger alert (default: 80)
MONITOR_ALERT_COOLDOWN=300000     # Cooldown between repeated alerts in ms (default: 300000 = 5 min)

